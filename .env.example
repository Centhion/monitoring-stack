# Enterprise Monitoring and Dashboarding Platform
# Copy this file to .env and fill in your environment-specific values.
# NEVER commit .env to version control.

# -- Prometheus --
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_RETENTION_DAYS=30

# -- Loki --
LOKI_URL=http://loki:3100

# -- Grafana --
GRAFANA_URL=http://grafana:3000

# -- Alertmanager --
ALERTMANAGER_URL=http://alertmanager:9093

# -- Microsoft Teams Notifications --
# Create an Incoming Webhook in your Teams monitoring channel and paste the URL here.
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/YOUR_WEBHOOK_URL_HERE

# -- Email Notifications (SMTP) --
# SMTP relay for sending alert emails. All Alertmanager email receivers
# use these global SMTP settings.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=monitoring@example.com
SMTP_AUTH_USERNAME=monitoring@example.com
SMTP_AUTH_PASSWORD=changeme

# -- Default Email (catch-all for unmapped datacenters) --
ALERT_EMAIL_TO=ops-team@example.com

# -- Per-Site Email Distribution Lists --
# Each site/datacenter maps to an ops team email DL. These match the
# `datacenter` label on alerts and route to the corresponding receiver
# in alertmanager.yml. Add entries for each site in your fleet.
# Convention: SITE_<NAME>_EMAIL where <NAME> matches the datacenter label.
SITE_A_EMAIL=site-a-ops@example.com
SITE_B_EMAIL=site-b-ops@example.com
SITE_C_EMAIL=site-c-ops@example.com

# -- Alloy Agent Labels --
# Set these on every server running an Alloy agent.
# ALLOY_ENV=prod
# ALLOY_DATACENTER=site-alpha
# ALLOY_ROLE=generic

# -- Redfish BMC Credentials (Phase 7B -- uncomment when using hardware monitoring) --
# REDFISH_USER=svc-monitoring
# REDFISH_PASSWORD=changeme

# -- LDAP Bind Password (Phase 8 -- uncomment when using LDAP auth) --
# LDAP_BIND_PASSWORD=changeme

# -- Mimir (Phase 6 -- uncomment when ready) --
# MIMIR_URL=http://mimir:9009
# MIMIR_OBJECT_STORAGE_BUCKET=monitoring-metrics
# MIMIR_OBJECT_STORAGE_ENDPOINT=s3.amazonaws.com
