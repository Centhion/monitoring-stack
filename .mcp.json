{
  "mcpServers": {
    "_example_http_server": {
      "type": "http",
      "url": "${API_BASE_URL:-https://api.example.com}/mcp",
      "headers": {
        "Authorization": "Bearer ${API_KEY}"
      },
      "_comment": "Remove underscore prefix to enable. Set API_KEY in .env"
    },
    "_example_stdio_server": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@example/mcp-server"],
      "_comment": "Remove underscore prefix to enable"
    }
  }
}
