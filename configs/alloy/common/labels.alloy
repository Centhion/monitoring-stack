// =============================================================================
// Standard Label Taxonomy
// =============================================================================
// Applied to all metrics and logs across the fleet. These labels enable
// consistent filtering, grouping, and routing in Grafana dashboards and
// Alertmanager rules.
//
// Environment variables must be set on each server before Alloy starts:
//   ALLOY_ENV        -- deployment environment (prod, staging, dev)
//   ALLOY_DATACENTER -- physical or logical datacenter (us-east-1, denver-dc)
//   ALLOY_ROLE       -- server role (dc, sql, iis, fileserver, docker, generic)
//
// The "os" label is set statically per OS-specific config (windows/base.alloy
// or linux/base.alloy). The "hostname" label is auto-detected by Alloy.
// =============================================================================

// Relabel rules that inject standard labels into all Prometheus metrics.
// OS-specific base configs forward their scraped metrics through this
// component before sending to remote_write.
prometheus.relabel "add_standard_labels" {
  forward_to = [prometheus.remote_write.default.receiver]

  rule {
    target_label = "environment"
    replacement  = sys.env("ALLOY_ENV")
  }

  rule {
    target_label = "datacenter"
    replacement  = sys.env("ALLOY_DATACENTER")
  }

  rule {
    target_label = "role"
    replacement  = sys.env("ALLOY_ROLE")
  }

  rule {
    target_label = "hostname"
    replacement  = constants.hostname
  }

  // Alloy v1.13+ uses "integrations/<exporter>" as the default job name
  // for built-in exporters, overriding the scrape config's job_name.
  // This rule forces the job label back to the expected value so it
  // matches recording rules, alert rules, and dashboard queries.
  // The actual job_name is set by each prometheus.scrape block (e.g.,
  // "windows_base", "linux_base") and arrives as a source label.
  rule {
    source_labels = ["job"]
    regex         = "integrations/windows"
    target_label  = "job"
    replacement   = "windows_base"
  }

  rule {
    source_labels = ["job"]
    regex         = "integrations/node_exporter"
    target_label  = "job"
    replacement   = "linux_base"
  }
}

// Loki processing stage that injects standard labels into all log streams.
// OS-specific log collectors forward through this component before sending
// to the Loki write endpoint.
loki.process "add_standard_labels" {
  forward_to = [loki.write.default.receiver]

  stage.static_labels {
    values = {
      environment = sys.env("ALLOY_ENV"),
      datacenter  = sys.env("ALLOY_DATACENTER"),
      role        = sys.env("ALLOY_ROLE"),
      hostname    = constants.hostname,
    }
  }
}
