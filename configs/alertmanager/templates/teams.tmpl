{{/* =======================================================================
  Microsoft Teams Webhook Message Template
  =========================================================================
  Formats Alertmanager notifications into Adaptive Card JSON for Teams
  incoming webhooks. Each notification includes:
    - Alert status (firing/resolved) with color coding
    - Alert name and severity
    - Affected server hostname
    - Summary and description from alert annotations
    - Link to relevant Grafana dashboard

  Teams Incoming Webhooks accept Adaptive Card JSON payloads.
  ======================================================================= */}}

{{ define "teams.card" }}
{
  "type": "message",
  "attachments": [
    {
      "contentType": "application/vnd.microsoft.card.adaptive",
      "content": {
        "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
        "type": "AdaptiveCard",
        "version": "1.4",
        "body": [
          {
            "type": "TextBlock",
            "text": "{{ if eq .Status "firing" }}FIRING{{ else }}RESOLVED{{ end }} - {{ .GroupLabels.alertname }}",
            "weight": "Bolder",
            "size": "Large",
            "color": "{{ if eq .Status "firing" }}Attention{{ else }}Good{{ end }}"
          },
          {
            "type": "FactSet",
            "facts": [
              {
                "title": "Status",
                "value": "{{ .Status | toUpper }}"
              },
              {
                "title": "Severity",
                "value": "{{ (index .Alerts 0).Labels.severity }}"
              },
              {
                "title": "Host",
                "value": "{{ (index .Alerts 0).Labels.hostname }}"
              },
              {
                "title": "Environment",
                "value": "{{ (index .Alerts 0).Labels.environment }}"
              },
              {
                "title": "Datacenter",
                "value": "{{ (index .Alerts 0).Labels.datacenter }}"
              },
              {
                "title": "Alerts",
                "value": "{{ len .Alerts }} alert(s)"
              }
            ]
          },
          {
            "type": "TextBlock",
            "text": "{{ (index .Alerts 0).Annotations.summary }}",
            "wrap": true,
            "weight": "Bolder"
          },
          {
            "type": "TextBlock",
            "text": "{{ (index .Alerts 0).Annotations.description }}",
            "wrap": true,
            "isSubtle": true
          }
        ]
      }
    }
  ]
}
{{ end }}
