    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "All Redfish-monitored servers with current health status, power state, peak temperature, and power consumption.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Health" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-background" } },
              { "id": "mappings", "value": [{ "options": { "0": { "color": "green", "text": "OK" }, "1": { "color": "orange", "text": "Warning" }, "2": { "color": "red", "text": "Critical" } }, "type": "value" }] },
              { "id": "custom.width", "value": 90 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Power" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-background" } },
              { "id": "mappings", "value": [{ "options": { "0": { "color": "red", "text": "OFF" }, "1": { "color": "green", "text": "ON" } }, "type": "value" }] },
              { "id": "custom.width", "value": 70 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Max Temp" },
            "properties": [
              { "id": "unit", "value": "celsius" },
              { "id": "custom.width", "value": 100 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 75 }, { "color": "red", "value": 85 }] } },
              { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Power Draw" },
            "properties": [
              { "id": "unit", "value": "watt" },
              { "id": "custom.width", "value": 110 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Server" },
            "properties": [{ "id": "custom.width", "value": 220 }]
          },
          {
            "matcher": { "id": "byName", "options": "BMC IP" },
            "properties": [{ "id": "custom.width", "value": 130 }]
          },
          {
            "matcher": { "id": "byName", "options": "Vendor" },
            "properties": [{ "id": "custom.width", "value": 80 }]
          },
          {
            "matcher": { "id": "byName", "options": "Site" },
            "properties": [{ "id": "custom.width", "value": 120 }]
          }
        ]
