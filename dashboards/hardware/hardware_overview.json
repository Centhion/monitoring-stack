          "format": "table",
          "instant": true,
          "legendFormat": "",
          "range": false,
          "refId": "Health"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "exemplar": false,
          "expr": "redfish_power_state{job=\"redfish\", datacenter=~\"$datacenter\", environment=~\"$environment\", vendor=~\"$vendor\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "range": false,
          "refId": "Power"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "exemplar": false,
          "expr": "server:temperature_max:celsius{datacenter=~\"$datacenter\", environment=~\"$environment\", vendor=~\"$vendor\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "range": false,
          "refId": "Temp"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "exemplar": false,
          "expr": "server:power_consumed:watts{datacenter=~\"$datacenter\", environment=~\"$environment\", vendor=~\"$vendor\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "range": false,
          "refId": "PowerDraw"
        }
      ],
      "title": "Server Health Inventory",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "environment": true, "device_type": true, "bmc_type": true },
            "renameByName": {
              "datacenter": "Site",
              "device_name": "Server",
              "instance": "BMC IP",
              "vendor": "Vendor",
              "Value #Health": "Health",
              "Value #Power": "Power",
              "Value #Temp": "Max Temp",
              "Value #PowerDraw": "Power Draw"
            }
          }
        }
      ],
      "type": "table"
    },
