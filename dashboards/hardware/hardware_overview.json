      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "pluginVersion": "10.4.0",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "editorMode": "code", "expr": "sum(site:hardware_healthy:count{datacenter=~\"$datacenter\", environment=~\"$environment\"}) or vector(0)", "legendFormat": "", "range": true, "refId": "A" }],
