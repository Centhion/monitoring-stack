        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "description": "Drive health status across all monitored servers. Non-zero values indicate degraded drives.",
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
              "mappings": [{ "options": { "0": { "color": "green", "text": "OK" } }, "type": "value" }, { "options": { "from": 1, "result": { "color": "red", "text": "Degraded" }, "to": 999 }, "type": "range" }],
              "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
            },
            "overrides": [
              {
                "matcher": { "id": "byName", "options": "Status" },
                "properties": [
                  { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-background" } },
                  { "id": "custom.width", "value": 100 }
                ]
              }
