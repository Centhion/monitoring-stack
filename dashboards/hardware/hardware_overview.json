          "targets": [{
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "editorMode": "code",
            "exemplar": false,
            "expr": "redfish_drive_health{job=\"redfish\", datacenter=~\"$datacenter\", environment=~\"$environment\", vendor=~\"$vendor\"}",
            "format": "table",
            "instant": true,
            "legendFormat": "",
            "range": false,
            "refId": "A"
          }],
          "title": "Drive Health",
          "transformations": [{
            "id": "organize",
            "options": {
              "excludeByName": { "Time": true, "__name__": true, "job": true, "environment": true, "device_type": true, "bmc_type": true },
              "renameByName": { "datacenter": "Site", "device_name": "Server", "instance": "BMC IP", "vendor": "Vendor", "Value": "Status", "drive": "Drive" }
            }
          }],
          "type": "table"
