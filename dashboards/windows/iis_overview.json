    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 500,
      "title": "Service Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "State of IIS core Windows services. W3SVC (World Wide Web Publishing) and WAS (Windows Process Activation) must be running for IIS to serve requests. IISADMIN manages IIS configuration. WMSVC enables remote IIS management.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "color-text" },
            "inspect": false
          },
          "mappings": [
            { "options": { "1": { "color": "green", "text": "Running" } }, "type": "value" },
            { "options": { "0": { "color": "red", "text": "Stopped" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "hostname" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          },
          {
            "matcher": { "id": "byName", "options": "name" },
            "properties": [{ "id": "custom.width", "value": 150 }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 34 },
      "id": 11,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Value" }]
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "windows_service_state{name=~\"W3SVC|WAS|IISADMIN|WMSVC\", state=\"running\", environment=~\"$environment\", datacenter=~\"$datacenter\", hostname=~\"$hostname\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
