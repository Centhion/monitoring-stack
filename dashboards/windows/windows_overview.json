      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "rate(windows_logical_disk_read_bytes_total{volume!~\"HarddiskVolume.*\", hostname=~\"$hostname\", environment=~\"$environment\", datacenter=~\"$datacenter\", role=~\"$role\"}[5m])",
          "legendFormat": "{{ hostname }} - {{ volume }} Read",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "rate(windows_logical_disk_write_bytes_total{volume!~\"HarddiskVolume.*\", hostname=~\"$hostname\", environment=~\"$environment\", datacenter=~\"$datacenter\", role=~\"$role\"}[5m])",
          "legendFormat": "{{ hostname }} - {{ volume }} Write",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Disk Read/Write Throughput",
