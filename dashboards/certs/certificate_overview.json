    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 8,
      "title": "Certificate Inventory",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "All monitored certificates with days until expiry, color-coded by urgency. Click a service name to see probe details.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Days Remaining" },
            "properties": [
              { "id": "decimals", "value": 1 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "dark-red", "value": null },
                    { "color": "red", "value": 0 },
                    { "color": "orange", "value": 7 },
                    { "color": "yellow", "value": 30 },
                    { "color": "green", "value": 90 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": { "mode": "basic", "type": "color-background" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "service" },
            "properties": [{ "id": "custom.width", "value": 180 }]
          },
          {
            "matcher": { "id": "byName", "options": "instance" },
            "properties": [{ "id": "custom.width", "value": 280 }]
          },
          {
            "matcher": { "id": "byName", "options": "cert_type" },
            "properties": [{ "id": "custom.width", "value": 80 }]
          },
          {
            "matcher": { "id": "byName", "options": "owner" },
            "properties": [{ "id": "custom.width", "value": 120 }]
          },
          {
            "matcher": { "id": "byName", "options": "datacenter" },
            "properties": [{ "id": "custom.width", "value": 140 }]
          },
          {
            "matcher": { "id": "byName", "options": "Probe OK" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              {
                "id": "mappings",
                "value": [
                  { "options": { "0": { "text": "FAIL", "color": "red" }, "1": { "text": "OK", "color": "green" } }, "type": "value" }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": { "mode": "basic", "type": "color-background" }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 6 },
      "id": 9,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Days Remaining" }]
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code", "exemplar": false,
          "expr": "instance:cert_days_remaining:gauge{datacenter=~\"$datacenter\", environment=~\"$environment\", cert_type=~\"$cert_type\"}",
          "format": "table", "instant": true, "legendFormat": "__auto",
          "range": false, "refId": "DaysRemaining"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code", "exemplar": false,
          "expr": "probe_success{job=\"cert_monitor\", datacenter=~\"$datacenter\", environment=~\"$environment\", cert_type=~\"$cert_type\"}",
          "format": "table", "instant": true, "legendFormat": "__auto",
          "range": false, "refId": "ProbeSuccess", "hide": false
        }
      ],
      "title": "Certificate Inventory",
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": { "byField": "instance" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "job": true,
              "job 1": true,
              "job 2": true,
              "__name__": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "datacenter 1": true,
              "environment 1": true,
              "cert_type 1": true,
              "owner 1": true,
              "service 1": true
            },
            "indexByName": {
              "service": 0,
              "instance": 1,
              "datacenter": 2,
              "cert_type": 3,
              "owner": 4,
              "Value #DaysRemaining": 5,
              "Value #ProbeSuccess": 6,
              "environment": 7
            },
            "renameByName": {
              "Value #DaysRemaining": "Days Remaining",
              "Value #ProbeSuccess": "Probe OK"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
