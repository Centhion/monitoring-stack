      "pluginVersion": "10.4.0",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "editorMode": "code",
        "expr": "count(instance:cert_days_remaining:gauge{datacenter=~\"$datacenter\", environment=~\"$environment\", cert_type=~\"$cert_type\"} >= 90) or vector(0)",
        "legendFormat": "Healthy", "range": true, "refId": "A"
      }],
      "title": "Healthy (>90d)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Certificates expiring within 30-90 days. Plan renewal.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 }
          ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 4,
