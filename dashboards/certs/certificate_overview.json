      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "editorMode": "code",
        "expr": "count(instance:cert_days_remaining:gauge{datacenter=~\"$datacenter\", environment=~\"$environment\", cert_type=~\"$cert_type\"} < 90 and instance:cert_days_remaining:gauge{datacenter=~\"$datacenter\", environment=~\"$environment\", cert_type=~\"$cert_type\"} >= 30) or vector(0)",
        "legendFormat": "Expiring", "range": true, "refId": "A"
      }],
      "title": "Expiring (30-90d)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Certificates expiring within 30 days. Renewal should be in progress.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 }
          ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto", "wideLayout": true
      },
      "pluginVersion": "10.4.0",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "editorMode": "code",
        "expr": "count(instance:cert_days_remaining:gauge{datacenter=~\"$datacenter\", environment=~\"$environment\", cert_type=~\"$cert_type\"} < 30 and instance:cert_days_remaining:gauge{datacenter=~\"$datacenter\", environment=~\"$environment\", cert_type=~\"$cert_type\"} > 0) or vector(0)",
        "legendFormat": "Urgent", "range": true, "refId": "A"
      }],
      "title": "Urgent (<30d)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Certificates expiring within 7 days. Immediate action required.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 6,
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto", "wideLayout": true
      },
      "pluginVersion": "10.4.0",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "editorMode": "code",
        "expr": "count(instance:cert_days_remaining:gauge{datacenter=~\"$datacenter\", environment=~\"$environment\", cert_type=~\"$cert_type\"} > 0 and instance:cert_days_remaining:gauge{datacenter=~\"$datacenter\", environment=~\"$environment\", cert_type=~\"$cert_type\"} < 7) or vector(0)",
        "legendFormat": "Critical", "range": true, "refId": "A"
      }],
      "title": "Critical (<7d)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Certificates that have already expired.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "dark-red", "value": 1 }
          ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 7,
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto", "wideLayout": true
      },
      "pluginVersion": "10.4.0",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "editorMode": "code",
        "expr": "count(instance:cert_days_remaining:gauge{datacenter=~\"$datacenter\", environment=~\"$environment\", cert_type=~\"$cert_type\"} <= 0) or vector(0)",
        "legendFormat": "Expired", "range": true, "refId": "A"
      }],
      "title": "Expired",
      "type": "stat"
