        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "editorMode": "code",
        "expr": "instance:cert_days_remaining:gauge{datacenter=~\"$datacenter\", environment=~\"$environment\", cert_type=~\"$cert_type\"}",
        "legendFormat": "{{service}} ({{cert_type}})",
        "range": true, "refId": "A"
      }],
      "title": "Certificate Expiry Timeline",
      "type": "timeseries"
