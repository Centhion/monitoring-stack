    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Time taken by each blackbox probe. High latency may indicate network issues or slow TLS handshakes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
