            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (os) (count_over_time({hostname=~\"$hostname\", environment=~\"$environment\", datacenter=~\"$datacenter\"} [$__interval]))",
          "legendFormat": "{{os}}",
