          "format": "table",
          "instant": true,
          "legendFormat": "",
          "range": false,
          "refId": "Status"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "exemplar": false,
          "expr": "sysUpTime{job=\"snmp\", datacenter=~\"$datacenter\", environment=~\"$environment\", device_type=~\"$device_type\"} / 100",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "range": false,
          "refId": "Uptime"
        }
