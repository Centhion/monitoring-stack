      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "environment": true },
            "renameByName": {
              "datacenter": "Site",
              "device_name": "Device",
              "device_type": "Type",
              "instance": "IP Address",
              "Value #Status": "Status",
              "Value #Uptime": "Uptime",
              "vendor": "Vendor"
            }
          }
        }
      ],
      "type": "table"
    },
